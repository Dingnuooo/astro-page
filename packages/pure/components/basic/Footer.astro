---
import config from 'virtual:config'

import { Icon } from '../user'

const footerConf = config.footer
const social = footerConf.social || []

const footerLink1 = footerConf.links?.filter(({ pos }) => pos === 1) || []
---

<footer class='mx-auto mb-5 mt-16 w-full'>
  <div class='border-t pt-3'>
    <div class='flex items-center gap-y-3 max-sm:flex-col sm:justify-between sm:gap-y-0'>
      <div
        class='flex items-center gap-x-4 gap-y-2 text-muted-foreground max-sm:flex-col [&_a]:text-foreground text-sm'
      >
        {/* year & author */}
        <div>
          {config.footer.year}
          {config.author}
          {
            footerConf.links && footerConf.links.length > 0 && (
              <>
                <span>
                  {footerConf.links
                    .filter(({ pos }) => pos === 2)
                    .map(({ title, link, style }) => (
                      <span>
                        <a href={link} target={title === 'Travelling' ? '_blank' : undefined} rel={title === 'Travelling' ? 'noopener noreferrer' : undefined} class={style}>
                          {title}
                        </a>
                      </span>
                    ))}
                </span>
              </>
            )
          }
        </div>
        {/* Powered by */}
        {
          footerConf.credits && (
            <span>
              Powered by
              <a href='https://github.com/withastro/astro' target='_blank'>
                Astro
              </a>
              &
              Theme.<a href='https://github.com/cworld1/astro-theme-pure' target='_blank' rel="noopener noreferrer">Pure</a>
            </span>
          )
        }
        {/* ICP */}
        {
          footerLink1.length > 0 && (
            <div>
              {footerLink1.map(({ title, link, style }, index) => (
                <span>
                  <a href={link} target='_blank' rel='noopener noreferrer' class={style}>
                    {title}
                  </a>
                  {index < footerLink1.length - 1 && ' • '}
                </span>
              ))}
            </div>
          )
        }
        
        
      </div>

      {/* Social Brands */}
      <div class='flex items-center gap-x-4'>
        {
          social.map(({ label, href, icon }) => (
            <a {href} rel='me' class='sl-flex'>
              <span class='sr-only'>{label}</span>
              <Icon name={icon} />
            </a>
          ))
        }
      </div>
    </div>
  </div>
</footer>

<style>
  footer a {
    color: hsl(var(--foreground) / var(--un-text-opacity, 1));
    text-decoration: none;
    font-weight: 500;
  }
</style>
