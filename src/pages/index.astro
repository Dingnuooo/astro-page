<script is:inline>
  (() => {
    const profile = document.querySelector('[data-profile-hover]')
    const trigger = document.querySelector('[data-avatar-trigger]')

    if (!(profile instanceof HTMLElement) || !(trigger instanceof HTMLElement)) {
      return
    }

    const activate = () => {
      profile.classList.add('is-clicked')
      document.body.classList.add('profile-clicked')
    }

    const reset = () => {
      profile.classList.remove('is-clicked')
      document.body.classList.remove('profile-clicked')
    }

    trigger.addEventListener('click', activate)
    trigger.addEventListener('keydown', (event) => {
      if (event.key === 'Enter' || event.key === ' ') {
        event.preventDefault()
        activate()
      }
    })
    profile.addEventListener('mouseleave', reset)
  })()
</script>

<style>
  .profile-hover {
    --avatar-transition: 0.35s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .avatar-hover-wrap {
    position: relative;
    overflow: hidden;
    border-radius: 9999px;
  }

  .avatar-layer {
    transition:
      transform var(--avatar-transition),
      box-shadow var(--avatar-transition),
      clip-path 0.45s cubic-bezier(0.22, 1, 0.36, 1),
      opacity var(--avatar-transition);
    will-change: transform, clip-path, opacity;
  }

  .avatar-base {
    position: relative;
    z-index: 0;
  }

  .avatar-alt {
    position: absolute;
    inset: 0;
    z-index: 1;
    clip-path: polygon(120% -10%, 120% 10%, 85% 110%, 85% 90%);
  }

  .avatar-hover-wrap:hover .avatar-layer {
    transform: scale(1.1);
    box-shadow: 0 0 10px 2px rgba(var(--highlight-color-rgb, 214, 231, 255), 0.4);
  }

  .profile-hover.is-clicked .avatar-layer {
    transform: scale(1.1);
    box-shadow: 0 0 10px 2px rgba(var(--highlight-color-rgb, 214, 231, 255), 0.4);
  }

  .profile-hover.is-clicked .avatar-alt {
    clip-path: polygon(0 0, 100% 0, 100% 100%, 0 100%);
  }

  .author-switch {
    position: relative;
    display: inline-grid;
    min-height: 1.3em;
  }

  .author-switch > span {
    grid-area: 1 / 1;
    transition:
      transform var(--avatar-transition),
      opacity var(--avatar-transition);
  }

  .author-alt {
    opacity: 0;
    transform: translateY(35%);
  }

  .profile-hover.is-clicked .author-default {
    opacity: 0;
    transform: translateY(-35%);
  }

  .profile-hover.is-clicked .author-alt {
    opacity: 1;
    transform: translateY(0);
  }

  :global(#highlight-gradient) {
    overflow: hidden;
  }

  :global(#highlight-gradient)::after {
    content: '';
    position: absolute;
    inset: 0;
    background-image: linear-gradient(#b54ccf, transparent);
    opacity: 0;
    transition: opacity 0.45s cubic-bezier(0.22, 1, 0.36, 1);
  }

  :global(body.profile-clicked #highlight-gradient::after) {
    opacity: 1;
  }

  @media (prefers-reduced-motion: reduce) {
    .avatar-layer,
    .author-switch > span,
    :global(#highlight-gradient)::after {
      transition: none;
    }
  }
</style>
