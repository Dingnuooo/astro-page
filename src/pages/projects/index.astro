<script>
  const themedSnakeVars = {
    '--cb': 'var(--snake-cb)',
    '--cs': 'var(--snake-cs)',
    '--ce': 'var(--snake-ce)',
    '--c0': 'var(--snake-c0)',
    '--c1': 'var(--snake-c1)',
    '--c2': 'var(--snake-c2)',
    '--c3': 'var(--snake-c3)',
    '--c4': 'var(--snake-c4)'
  }

  let githubSnakeSvgRequest: Promise<string> | undefined

  function fetchGithubSnakeSvg(src: string) {
    if (githubSnakeSvgRequest) {
      return githubSnakeSvgRequest
    }

    githubSnakeSvgRequest = fetch(src)
      .then(async (response) => {
        if (!response.ok) {
          throw new Error(`Failed to fetch snake SVG: ${response.status}`)
        }

        return response.text()
      })
      .catch((error) => {
        githubSnakeSvgRequest = undefined
        throw error
      })

    return githubSnakeSvgRequest
  }

  async function mountGithubSnake(container: HTMLElement) {
    const src = container.dataset.src

    if (!src || container.dataset.loaded === 'pending' || container.dataset.loaded === 'true') {
      return
    }

    container.dataset.loaded = 'pending'

    try {
      const rawSvg = await fetchGithubSnakeSvg(src)

      if (!container.isConnected || !isProjectsPageActive(container) || !isPageVisible()) {
        container.dataset.loaded = 'idle'
        return
      }

      const parsed = new DOMParser().parseFromString(rawSvg, 'image/svg+xml')
      const svg = parsed.documentElement

      if (svg.tagName.toLowerCase() !== 'svg') {
        throw new Error('Snake SVG parsing failed')
      }

      svg.setAttribute('class', 'github-snake-svg')
      svg.setAttribute('role', 'img')
      svg.setAttribute('aria-label', 'GitHub contribution snake')
      svg.removeAttribute('width')
      svg.removeAttribute('height')
      Object.entries(themedSnakeVars).forEach(([name, value]) => {
        svg.style.setProperty(name, value)
      })

      container.replaceChildren(svg)
      container.dataset.loaded = 'true'
    } catch {
      container.dataset.loaded = 'error'
    }
  }

  function normalizePath(path: string) {
    return path.replace(/\/$/, '') || '/'
  }

  function isPageVisible() {
    const prerenderingDocument = document as Document & { prerendering?: boolean }
    return document.visibilityState === 'visible' && prerenderingDocument.prerendering !== true
  }

  function isProjectsPageActive(container: HTMLElement) {
    const pagePath = container.dataset.pagePath
    if (!pagePath) return false

    return normalizePath(window.location.pathname) === normalizePath(pagePath)
  }

  function initGithubSnake() {
    const container = document.getElementById('github-snake') as HTMLElement | null
    if (!container) return

    const src = container.dataset.src
    if (src) {
      void fetchGithubSnakeSvg(src)
    }

    if (!isProjectsPageActive(container) || !isPageVisible()) {
      return
    }

    void mountGithubSnake(container)
  }

  initGithubSnake()
  document.addEventListener('astro:page-load', initGithubSnake)
  document.addEventListener('visibilitychange', initGithubSnake)
  document.addEventListener('prerenderingchange', initGithubSnake)
  window.addEventListener('pageshow', initGithubSnake)
</script>

<style>
  .github-snake {
