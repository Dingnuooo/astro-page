    --snake-cs: #284779;
    --snake-ce: #edebe6;
    --snake-c0: #edebe6;
    --snake-c1: #9dc7f1;
    --snake-c2: #428fdc;
    --snake-c3: #2f68b4;
    --snake-c4: #284779;
  }

  :global(html.dark) .github-snake {
