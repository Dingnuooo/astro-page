---
import { Button, Collapse, Spoiler, Timeline } from 'astro-pure/user'
import PageLayout from '@/layouts/CommonPage.astro'
import Substats from '@/components/about/Substats.astro'
import ToolSection from '@/components/about/ToolSection.astro'
import DynamicSignature from '@/components/DynamicSignature.astro'
import { highlightColor } from '@/site-config'

import zotero from '@/assets/tools/zotero.png'

const headings = [
  { depth: 2, slug: 'findme', text: 'Profiles' },
  { depth: 2, slug: 'tools', text: 'Tools' },
  //{ depth: 2, slug: 'gossips', text: 'Gossips' },
  { depth: 2, slug: 'colophon', text: 'Colophon' }
]
---

<PageLayout title='About' {headings} comment highlightColor={highlightColor}>
  <p>
    欢迎光临。我是丁诺（chinosan），在这里写一些笔记、灵感、藏书、独白等内容。广泛的调研阅读 与真诚的分享创作，是我认为一切思想与机遇的根源。
  </p>

  <!-- <h2 id='hobbies'>Hobbies</h2> -->
   
  <ul>
    <li>我的人格类型为 INTJ-T.</li>
    <li>我的的研究兴趣集中在 AgenticRL 与群体智能。</li>
    <li>我阅读推理小说，本格与社会派.</li>
    <li>底边 coser / 摄影低手. 随拍集 → <a href='/gallery' target='_blank'>Gallery</a>.</li>
    <li>我主要游玩 Minecraft（生电 / 建筑）与音乐游戏（プロセカ / Arcaea）.</li>
  </ul>
  
  <Button title='Sponsor Me' class='w-fit' href='/projects#sponsorship' variant='ahead' />

  {/* findme */}
  <h2 id='findme'>Profiles</h2>
  <p>
    您可以在以下平台找到我。
  </p>
  <Substats
    stats={[
      {
        platform: 'GitHub',
        icon: 'github',
        link: 'https://github.com/dingnuooo',
        desc: 'Code / Research',
        text: 'followers'
      },
      {
        platform: 'bilibili',
        icon: 'bilibili',
        color: '#ed7b98',
        link: 'https://space.bilibili.com/90563238',
        desc: 'Videos / Livestream',
        text: 'followers',
        // api: 'bilibili/90563238'
      },
      {
        platform: 'Rednote',
        icon: 'instagram',
        color: '#D94551',
        link: 'https://www.xiaohongshu.com/user/profile/623f388200000000100067db',
        desc: 'Photography',
        text: 'followers'
      },
      {
        platform: 'twitter',
        icon: 'x',
        color: '#7fbeff',
        link: 'https://x.com/chinosan_dn',
